  "query": "SELECT c.id, c.name, COUNT(mcl.media_id) as \"usage_count!\"\n               FROM catalog c\n               LEFT JOIN media_catalog_link mcl ON c.id = mcl.catalog_id\n               GROUP BY c.id, c.name\n               ORDER BY c.name\n               LIMIT $1 OFFSET $2",
