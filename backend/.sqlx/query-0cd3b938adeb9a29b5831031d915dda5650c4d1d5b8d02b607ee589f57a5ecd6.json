  "query": "\n        SELECT g.name\n        FROM genre g\n        JOIN media_genre_link mgl ON mgl.genre_id = g.id\n        WHERE mgl.media_id = $1\n          AND lower(g.name) <> ALL($2)\n        ORDER BY g.name\n        ",
