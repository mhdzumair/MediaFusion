  "query": "SELECT pc.id, pc.name, COUNT(mpcl.media_id) as \"usage_count!\"\n               FROM parental_certificate pc\n               LEFT JOIN media_parental_certificate_link mpcl ON pc.id = mpcl.certificate_id\n               GROUP BY pc.id, pc.name\n               ORDER BY pc.name\n               LIMIT $1 OFFSET $2",
