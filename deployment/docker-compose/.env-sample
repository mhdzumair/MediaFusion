# =============================================================================
# MediaFusion Environment Configuration
# =============================================================================

# Application URLs
HOST_URL="https://mediafusion.local"
POSTER_HOST_URL="https://mediafusion.local"
CONTACT_EMAIL="admin@example.com"
# Default UI theme pack for first-time visitors
# (mediafusion, cinematic, ocean, forest, emeraldnight, midnight, arctic, slate, rose, purple, sunset, youtube)
DEFAULT_COLOR_SCHEME="mediafusion"

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL Primary (read-write)
POSTGRES_URI="postgresql+asyncpg://mediafusion:mediafusion@postgres:5432/mediafusion"

# PostgreSQL Read Replica (optional - for high availability setups)
# Uncomment and configure if using read replicas
# POSTGRES_READ_URI="postgresql+asyncpg://mediafusion:mediafusion@postgres-replica:5432/mediafusion"

# SQLAlchemy pool budget per engine (pool_size + max_overflow)
DB_MAX_CONNECTIONS=50

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL="redis://redis:6379"

# =============================================================================
# Prowlarr Configuration
# =============================================================================
PROWLARR_URL="http://prowlarr:9696"
PROWLARR_IMMEDIATE_MAX_PROCESS=30
PROWLARR_IMMEDIATE_MAX_PROCESS_TIME=30
PROWLARR_SEARCH_INTERVAL_HOUR="24"
prowlarr_live_title_search="true"

# =============================================================================
# Torznab Scraping (Global Endpoints)
# =============================================================================
# Enable global Torznab scraping and define endpoints as JSON array.
# Endpoint keys: name, url, optional headers, categories, priority, enabled, id.
IS_SCRAP_FROM_TORZNAB="false"
TORZNAB_ENDPOINTS='[]'
# Example:
# TORZNAB_ENDPOINTS='[{"name":"Indexer One","url":"https://indexer.example/api?apikey=xxx","enabled":true,"priority":1,"categories":[2000,5000],"headers":{"X-Api-Key":"optional"}}]'

# =============================================================================
# Scraping Configuration
# =============================================================================
IS_SCRAP_FROM_TORRENTIO="true"
is_scrap_from_mediafusion="true"
is_scrap_from_zilean="true"
store_stremthru_magnet_cache="false"
# Browserless CDP endpoint for Scrapling background browser tasks
SCRAPLING_CDP_URL="ws://browserless:3000"
# Enable browser-based Cloudflare solving in public indexers live search.
# Keep false for lower resource usage; enable only if you need solver-only sites.
PUBLIC_INDEXERS_LIVE_SEARCH_ENABLE_CLOUDFLARE_SOLVER="false"
# Route all queues (default/scrapy/import/priority) into one worker queue.
# Standard docker-compose uses this mode by default with one worker service.
# HA and K8s templates can set this to false for dedicated queue workers.
TASKIQ_SINGLE_WORKER_MODE="true"

# =============================================================================
# Rate Limiting
# =============================================================================
ENABLE_RATE_LIMIT="false"

# =============================================================================
# Security (Generate these values using openssl rand -hex 16)
# =============================================================================
SECRET_KEY=""
API_PASSWORD=""

# Startup behavior (set true for scale-up pods when DB is already provisioned)
# STARTUP_MIGRATE_ONLY=false

# Gunicorn runtime tuning
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
GUNICORN_MAX_REQUESTS=5000
GUNICORN_MAX_REQUESTS_JITTER=2000

# =============================================================================
# Optional: Streaming Provider OAuth
# =============================================================================
# Max number of streaming providers each profile can configure
MAX_STREAMING_PROVIDERS_PER_PROFILE=5
# Provider signup/referral links shown in Configure UI.
# JSON object of provider -> list of URLs. Any number of links is supported.
# Values provided here are appended to built-in defaults (defaults are retained).
# The UI randomly picks one link per provider display.
# PROVIDER_SIGNUP_LINKS='{"realdebrid":["https://real-debrid.com/?id=9999999"],"alldebrid":["https://alldebrid.com/?uid=custom"]}'

# PREMIUMIZE_OAUTH_CLIENT_ID=""
# PREMIUMIZE_OAUTH_CLIENT_SECRET=""
